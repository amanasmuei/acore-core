{
  "name": "@aman_asmuei/acore-core",
  "version": "0.1.1",
  "description": "The identity layer for the aman ecosystem — multi-tenant Identity records over MarkdownFileStorage (dev) and DatabaseStorage (server), built on @aman_asmuei/aman-core.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@aman_asmuei/aman-core": "^0.2.0",
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "aman",
    "acore",
    "identity",
    "multi-tenant",
    "ai-companion",
    "ecosystem"
  ],
  "license": "MIT",
  "author": "Aman Asmuei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amanasmuei/acore-core.git"
  }
}
